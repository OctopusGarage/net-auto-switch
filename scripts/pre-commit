#!/bin/bash
# Pre-commit hook: run the same gates as CI before a commit is allowed, so
# problems are caught locally instead of on GitHub. Install via
# scripts/install-hooks.sh. Bypass once with `git commit --no-verify`.
set -euo pipefail

# Resolve the repo root via git (this hook is a symlink, so $0's dirname is
# .git/hooks, not the script's real location).
cd "$(git rev-parse --show-toplevel)"

echo "[pre-commit] ruff check…"
uv run ruff check .

echo "[pre-commit] ruff format --check…"
uv run ruff format --check .

echo "[pre-commit] mypy…"
uv run mypy net_auto_switch

echo "[pre-commit] pytest…"
uv run pytest -q

# Shellcheck the shell scripts (optional locally; CI always enforces it).
echo "[pre-commit] shellcheck…"
if command -v shellcheck >/dev/null 2>&1; then
  shellcheck --severity=warning scripts/*.sh scripts/pre-commit install.sh
else
  echo "  (shellcheck not installed — skipping; CI still enforces it)"
fi

# Secret scan. Prefer gitleaks (full ruleset); fall back to a crude grep so the
# hook still offers some protection when gitleaks isn't installed.
echo "[pre-commit] secret scan…"
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --no-banner --config .gitleaks.toml
else
  echo "  (gitleaks not installed — using grep fallback; CI runs gitleaks)"
  if grep -rn "your-clash-api-secret\|/Users/[a-z]\+/\|/home/[a-z]\+/" \
      --include="*.py" net_auto_switch/ tests/; then
    echo "[pre-commit] ✗ found a secret or personal path above — aborting commit."
    exit 1
  fi
fi

echo "[pre-commit] ✓ all checks passed."
